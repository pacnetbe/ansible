services:
  netdata:
    image: netdata/netdata
    container_name: netdata
    pid: host
    restart: unless-stopped
    cap_add:
      - SYS_PTRACE
      - SYS_ADMIN
    security_opt:
      - apparmor:unconfined
    volumes:
      - netdataconfig:/etc/netdata
      - netdatalib:/var/lib/netdata
      - netdatacache:/var/cache/netdata
      - /:/host/root:ro,rslave
      - /etc/passwd:/host/etc/passwd:ro
      - /etc/group:/host/etc/group:ro
      - /etc/localtime:/etc/localtime:ro
      - /proc:/host/proc:ro
      - /sys:/host/sys:ro
      - /etc/os-release:/host/etc/os-release:ro
      - /var/log:/host/var/log:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - /run/dbus:/run/dbus:ro

    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.netdata-secure.rule=Host(`netdata.{{ inventory_hostname }}.lan`)"
      - "traefik.http.routers.netdata-secure.entrypoints=websecure"
      - "traefik.http.routers.netdata-secure.tls=true"
      - "traefik.http.routers.netdata-secure.service=netdata-svc"
      - "traefik.http.routers.netdata-plain.rule=Host(`netdata-{{ short_name }}.pacnet.be`)"
      - "traefik.http.routers.netdata-plain.entrypoints=web"
      - "traefik.http.routers.netdata-plain.service=netdata-svc"
      - "traefik.http.services.netdata-svc.loadbalancer.server.port=19999"

    networks:
      - proxy

volumes:
  netdataconfig:
  netdatalib:
  netdatacache:

networks:
  proxy:
    external: true

